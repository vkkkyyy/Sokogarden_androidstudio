<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="#245685"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

   <TextView
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:text="🥗SokoGarden"
       android:textSize="38sp"
       android:fontFamily="cursive"
       android:textAlignment="center"
       android:textStyle="bold|italic"
       android:autoSizeMaxTextSize="32dp"
       android:textColor="#DCE1E6"
       android:background="@drawable/shape"/>
<!--   Below is a linear layout  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅Sign up"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#048C7F"
            android:id="@+id/signupBtn"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤Sign in"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#048C7F"
            android:id="@+id/signinBtn"/>

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="24sp"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="10dp"
            android:backgroundTint="#ED0909"
            android:textColor="#F2F2F2"
            android:visibility="gone"/>

</LinearLayout>

<!--    Below is our progress bar -->
    <ProgressBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/progressbar"/>

<!--    below is our recycler/duplicate our view holders -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:listitem="@layout/single_item" />




</LinearLayout>